        </mxCell>
        <mxCell id="zfeU9tKfxxfzsF5zsc65-2" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;div class=&quot;panel-label&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 6px; padding: 0px; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: rgb(194, 192, 182); font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start;&quot;&gt;Step 1 — Argo Events&lt;/div&gt;&lt;div class=&quot;panel-title&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 4px; padding: 0px; font-size: medium; color: rgb(250, 249, 245); font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start;&quot;&gt;PR merged → webhook fires&lt;/div&gt;&lt;div class=&quot;panel-sub&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 16px; padding: 0px; font-size: 13px; color: rgb(194, 192, 182); line-height: 1.5; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start;&quot;&gt;The developer merges the PR into main. GitHub sends a webhook to Argo Events. This is the starting gun for the entire pipeline.&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-purple&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(238, 237, 254); color: rgb(60, 52, 137);&quot;&gt;EventSource&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;GitHub webhook EventSource is listening on the checkout repo for push events to main&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-purple&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(238, 237, 254); color: rgb(60, 52, 137);&quot;&gt;EventBus&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;Event flows into the NATS-powered EventBus inside the cluster — no polling needed&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-purple&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(238, 237, 254); color: rgb(60, 52, 137);&quot;&gt;Sensor&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;A Sensor detects the event and evaluates its condition: is this a push to main? Yes → fire trigger&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-purple&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(238, 237, 254); color: rgb(60, 52, 137);&quot;&gt;Trigger&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;Sensor submits a new Argo Workflow to the cluster with the commit SHA as a parameter&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="1030" x="500" y="1450" as="geometry" />
        </mxCell>
        <mxCell id="zfeU9tKfxxfzsF5zsc65-3" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;div class=&quot;panel-label&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 6px; padding: 0px; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: rgb(194, 192, 182); font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start;&quot;&gt;Step 2 — Argo Workflows&lt;/div&gt;&lt;div class=&quot;panel-title&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 4px; padding: 0px; font-size: medium; color: rgb(250, 249, 245); font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start;&quot;&gt;CI pipeline runs in the cluster&lt;/div&gt;&lt;div class=&quot;panel-sub&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 16px; padding: 0px; font-size: 13px; color: rgb(194, 192, 182); line-height: 1.5; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start;&quot;&gt;Argo Workflows picks up the submitted workflow and runs the full CI pipeline. Each step is a container running on Kubernetes — no external CI server needed.&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-teal&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(225, 245, 238); color: rgb(8, 80, 65);&quot;&gt;Step 1&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;Clone repo at commit a3f9d2c and install dependencies&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-teal&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(225, 245, 238); color: rgb(8, 80, 65);&quot;&gt;Step 2&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;Run unit tests and integration tests in parallel (DAG)&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-teal&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(225, 245, 238); color: rgb(8, 80, 65);&quot;&gt;Step 3&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;Build Docker image and push to ECR with tag checkout:a3f9d2c&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;detail-row&quot; style=&quot;box-sizing: border-box; margin: 0px 0px 8px; padding: 0px; display: flex; gap: 8px; align-items: flex-start; font-family: &amp;quot;Anthropic Sans&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;badge badge-teal&quot; style=&quot;box-sizing: border-box; margin: 1px 0px 0px; padding: 2px 8px; font-size: 11px; border-radius: 20px; flex-shrink: 0; background: rgb(225, 245, 238); color: rgb(8, 80, 65);&quot;&gt;Step 4&lt;/span&gt;&lt;span class=&quot;detail-text&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; font-size: 13px; color: rgb(250, 249, 245); line-height: 1.6;&quot;&gt;Update GitOps repo: patch checkout-deployment.yaml → image: checkout:a3f9d2c and open a commit&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="1030" x="500" y="1770" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
